# --- PostgreSQL ---
DB_USER=postgres
DB_PASS=sua_senha_aqui
DB_HOST=localhost
DB_PORT=5432
DB_NAME=data_lake

# --- APIs externas ---
OPEN_AI_API_KEY=sk-...
GITHUB_TOKEN=ghp_...
